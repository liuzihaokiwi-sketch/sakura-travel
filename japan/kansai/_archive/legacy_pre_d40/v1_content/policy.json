{
  "_doc": "机器可读的硬约束、退化规则和校验红线。原则性内容在brief.md，这里只放需要程序检查的规则",

  "hard_constraints": {
    "dining": {
      "same_day_no_repeat_cuisine": true,
      "same_day_no_two_flour_meals": true,
      "flour_cuisines": ["ramen", "udon", "okonomiyaki", "soba"],
      "consecutive_days_no_repeat_cuisine_in_A_track": true,
      "showcase_meal_max_per_city": 1,
      "showcase_meal_max_per_trip": 2,
      "family_never_top_tier": true,
      "no_chinese_cuisine": true,
      "chinese_exceptions": ["551_horai"],
      "reservation_5star_excluded": true,
      "reservation_5star_examples": ["尽誠", "mikami limited50", "京洛焼肉ぽめ（京洛烧肉ぽめ）", "本湖月", "もめん（蚊帐）"],
      "restaurant_must_be_in_day_area": true
    },
    "cross_city_dedup": {
      "dedup_scope": "A_track_only",
      "general_cuisine_max_across_trip": 2,
      "general_cuisines": ["ramen", "tempura", "izakaya", "udon", "yoshoku", "yakitori"],
      "second_occurrence_must_differ_meal_role": true,
      "priority_city": {
        "wagyu": "kobe",
        "sushi_omakase": "osaka",
        "kaiseki": "kyoto",
        "fugu": "osaka"
      },
      "city_exclusive_no_dedup": {
        "osaka": ["takoyaki", "kushikatsu", "okonomiyaki", "fugu", "551_horai"],
        "kyoto": ["kaiseki", "yudofu", "kyo_ryori", "matcha_sweets"],
        "kobe": ["kobe_beef"],
        "nara": ["kakinoha_sushi"]
      }
    },
    "assembly": {
      "transfer_day_afternoon_no_heavy_poi": true,
      "transfer_day_intensity": "light",
      "heavy_day_next_morning_must_be_light": true,
      "arrival_day_no_formal_poi": true,
      "departure_half_keep_light": true,
      "usj_day_never_cut_by_density": true,
      "audience_day_never_cut_core_sequence": true
    },
    "hotel": {
      "system_picks_one_not_user_chooses": true,
      "handbook_shows_one_plus_one_backup": true
    }
  },

  "budget_constraints": {
    "economy": { "max_mid_high_meals": 1, "max_high_meals": 0 },
    "mid": { "max_high_meals": 1, "min_economy_experience_meals": 1 },
    "high": { "max_top_meals": 1, "min_mid_or_lower_meals": 2 }
  },

  "day_type_dining_adjustments": {
    "arrival_day_lunch": -1,
    "usj_day_dinner": -1,
    "heavy_walking_day_dinner": -1,
    "audience_day_lunch": 1,
    "audience_day_dinner": { "min": 1, "max": 2 }
  },

  "party_dining_modifiers": {
    "couple": { "audience_day_dinner_bonus": 1, "allow_top_tier": true },
    "friends": { "audience_day_dinner_bonus": 1, "allow_top_tier": true },
    "family": { "overall_shift": -0.5, "audience_day_dinner_cap": "mid_high", "allow_top_tier": false },
    "default": { "audience_day_bonus": 1, "allow_top_tier": false }
  },

  "density_cut_rules": {
    "packed": { "cut_from": null, "note": "no cuts" },
    "balanced": { "cut_from": "P4" },
    "relaxed": { "cut_from": "P3" }
  },

  "shop_count_by_free_time": {
    "high": { "min_hours": 3, "count": 5 },
    "medium": { "min_hours": 1.5, "count": 3 },
    "low": { "min_hours": 0.5, "count": 2 },
    "none": { "min_hours": 0, "count": 0 }
  },

  "degradation_priority": {
    "_doc": "天数不够时的砍减优先级，数字越大越先砍",
    "order": [
      { "priority": 1, "item": "core_city_anchor", "action": "never_cut" },
      { "priority": 2, "item": "one_highlight_module", "action": "never_cut" },
      { "priority": 3, "item": "audience_memory_point", "action": "cut_last_resort" },
      { "priority": 4, "item": "secondary_anchor", "action": "cut_if_needed" },
      { "priority": 5, "item": "shops_cafe_shopping", "action": "cut_early" },
      { "priority": 6, "item": "photo_spots_extras", "action": "cut_first" }
    ]
  },

  "module_conflict_resolution": {
    "_doc": "用户勾选过多模块时的取舍规则",
    "rule": "rank_by_scarcity_then_time_then_irreplaceability",
    "squeezed_module_gets_explanation_text": true
  },

  "restaurant_fallback_order": {
    "_doc": "餐厅池不足时的退化顺序",
    "order": [
      "widen_walking_radius",
      "relax_budget_half_tier",
      "relax_B_requirement",
      "allow_A_only_no_B",
      "change_slot_role_keep_mainline"
    ]
  },

  "city_allocation": {
    "_doc": "城市天数分配规则。系统根据总天数+风格自动分配，不需要用户选城市",
    "city_min_days": {
      "osaka": 2.5,
      "kyoto": 2,
      "nara": 0.5,
      "kobe": 1,
      "arima_onsen": 1,
      "himeji": 1,
      "uji": 0.5,
      "koyasan": 1.5,
      "kinosaki": 1.5,
      "shirahama": 2
    },
    "transfer_cost_days": 0.5,
    "vibe_defaults": {
      "_doc": "各风格的默认城市偏好，天数不够时按此优先级分配",
      "classic": {"primary": ["osaka", "kyoto"], "secondary": ["nara"]},
      "romantic": {"primary": ["osaka", "kyoto"], "secondary": ["arima_onsen", "nara"]},
      "photogenic": {"primary": ["kyoto", "osaka"], "secondary": ["nara", "uji"]},
      "family_fun": {"primary": ["osaka", "kyoto"], "secondary": ["nara"]}
    },
    "vibe_default_experiences": {
      "_doc": "各风格默认包含的体验模块",
      "classic": [],
      "romantic": [],
      "photogenic": ["arashiyama"],
      "family_fun": ["usj"]
    },
    "auto_add_rules": {
      "_doc": "天数充裕时自动加入",
      "7+": ["nara"],
      "9+": ["kobe_or_onsen"]
    },
    "city_order_rules": {
      "_doc": "城市游览顺序规则，按总天数分两种模式",
      "7_days_or_less": {
        "order": ["kyoto", "osaka"],
        "reason": "行程短，体力最好时沉浸京都，大阪收尾容错率高"
      },
      "8_days_or_more": {
        "order": ["osaka", "kyoto", "izumisano"],
        "reason": "行程长，大阪先做适应缓冲，京都中段深度沉浸，泉佐野收尾衔接机场"
      }
    },
    "izumisano_trigger": {
      "_doc": "泉佐野（Vess温泉+临空城）收尾的触发条件，两个条件同时满足才推荐",
      "min_trip_days": 7,
      "departure_before": "14:00",
      "reason": "14点前航班住泉佐野15分钟到机场，消除最后一晚赶路焦虑；Vess温泉作为放松收尾"
    },
    "kyoto_base_mode_trigger": {
      "_doc": "京都超过5天后切换为'以京都为基地的日归模式'，不继续安排纯京都景点",
      "kyoto_days_threshold": 5,
      "daytrip_options": ["nara", "uji", "arashiyama", "kurama"],
      "reason": "连续5天以上纯京都会触发审美疲劳，日归周边保持新鲜感"
    },
    "uji_placement": {
      "_doc": "宇治安排在行程前期而非末尾",
      "preferred_position": "first_half",
      "reason": "宇治节奏极慢，需要'还有大把时间'的心理状态才能真正享受；行程末尾疲惫状态会觉得慢节奏是浪费时间"
    },
    "uji_cannot_combine_with": {
      "_doc": "宇治不能和以下城市放在同一天，宇治的灵魂是慢，和大景点组合变走马观花",
      "exclude_same_day": ["himeji", "nara"],
      "reason": "宇治内容量小但需要慢节奏消化，和姬路/奈良同天会让两边都没看到位"
    },
    "himeji_kobe_combo": {
      "_doc": "姬路+神户默认作为一天组合推荐，非强制",
      "recommended": true,
      "default_order": "himeji_morning_kobe_afternoon",
      "reason": "铁路顺路，姬路内容量约半天（城堡+好古园），神户下午港口+牛肉+酒造，组合一天效率最高",
      "override_condition": "用户对神户有强偏好时（有马温泉/牛肉深度体验）可拆开，神户单独1-2天，姬路单独半天"
    },
    "arrival_slot_capacity": {
      "morning": 1.0,
      "afternoon": 0.5,
      "evening": 0.25
    },
    "departure_slot_capacity": {
      "morning": 0.25,
      "afternoon": 0.5,
      "evening": 0.75
    }
  },

  "budget_mix_ratios": {
    "_doc": "餐饮升降档混搭比例，按天数和档位计算总费用时使用",
    "dining": {
      "street": {"base_pct": 0.75, "upgrade_pct": 0.15, "downgrade_pct": 0.10},
      "local_good": {"base_pct": 0.70, "upgrade_pct": 0.15, "downgrade_pct": 0.15},
      "fine": {"base_pct": 0.70, "upgrade_pct": 0.10, "downgrade_pct": 0.20},
      "top": {"base_pct": 0.65, "upgrade_pct": 0.10, "downgrade_pct": 0.25}
    },
    "dining_price_ranges_cny": {
      "street": {"low": 40, "high": 60},
      "local_good": {"low": 80, "high": 150},
      "fine": {"low": 200, "high": 350},
      "top": {"low": 500, "high": 800}
    },
    "hotel": {
      "budget": {"upgrade_nights_per_trip": 0},
      "comfort": {"upgrade_nights_per_7": 1},
      "premium": {"upgrade_nights_per_7": 1},
      "luxury": {"upgrade_nights_per_7": 1}
    },
    "hotel_price_ranges_cny": {
      "budget": {"low": 250, "high": 450},
      "comfort": {"low": 500, "high": 900},
      "premium": {"low": 1000, "high": 1800},
      "luxury": {"low": 2000, "high": 3500}
    }
  },

  "validation_checklist": {
    "_doc": "拼装完成后必须通过的检查项",
    "checks": [
      "no_same_cuisine_lunch_dinner_same_day",
      "no_consecutive_day_same_cuisine_A_track",
      "no_heavy_poi_on_transfer_afternoon",
      "no_two_consecutive_heavy_days",
      "showcase_meal_within_caps",
      "budget_distribution_within_constraints",
      "all_restaurants_in_day_area",
      "no_A_B_same_cuisine_same_role",
      "seasonal_events_date_matched_correctly",
      "cross_city_cuisine_within_caps",
      "audience_day_dining_matches_theme",
      "closing_scene_not_high_stimulus_after_peak"
    ]
  }
}
