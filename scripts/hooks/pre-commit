#!/bin/sh
# pre-commit hook: 防止 .env 文件被提交
# 安装: cp scripts/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

RED='\033[0;31m'
NC='\033[0m' # No Color

# 检查暂存区是否包含 .env 文件
ENV_FILES=$(git diff --cached --name-only | grep -E '^\.(env|env\.local|env\.production|env\..*\.local)$')

if [ -n "$ENV_FILES" ]; then
    echo "${RED}🚫 禁止提交 .env 文件！${NC}"
    echo ""
    echo "检测到以下敏感文件在暂存区："
    echo "$ENV_FILES"
    echo ""
    echo "请执行以下命令移除："
    for f in $ENV_FILES; do
        echo "  git reset HEAD $f"
    done
    echo ""
    exit 1
fi

exit 0