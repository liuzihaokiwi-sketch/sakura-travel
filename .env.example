# ============================================================
# Japan Travel AI - Environment Variables
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# ============================================================

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://japan_ai:japan_ai_dev@localhost:5432/japan_ai
POSTGRES_USER=japan_ai
POSTGRES_PASSWORD=japan_ai_dev
POSTGRES_DB=japan_ai

# ──────────────────────────────────────────────
# Redis / arq Worker
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ──────────────────────────────────────────────
# External APIs
# ──────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
AI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DEEPL_API_KEY=your_deepl_api_key_here
SERPAPI_KEY=your_serpapi_key_here

# ──────────────────────────────────────────────
# AI Model Tiered Selection
# ──────────────────────────────────────────────
AI_MODEL_LIGHT=gpt-4o-mini        # Tier 1: 标签/分类/翻译
AI_MODEL_STANDARD=gpt-4o          # Tier 2: 推荐理由/润色
AI_MODEL_STRONG=claude-sonnet     # Tier 3: 完整行程编排

# ──────────────────────────────────────────────
# Frontend → Backend 连接（必填）
# ──────────────────────────────────────────────
# 内网穿透地址（ngrok / frp / Cloudflare Tunnel）
# 浏览器端调用（quiz 问卷提交、admin 管理后台）
NEXT_PUBLIC_API_URL=https://你的穿透地址

# 服务端 Route Handler 调用（plan、pricing、swap 等）
BACKEND_URL=https://你的穿透地址

# ──────────────────────────────────────────────
# App Settings
# ──────────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_DEBUG=true
SECRET_KEY=change_me_to_a_random_secret_key_in_production
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]
ADMIN_PASSWORD=admin123

# ──────────────────────────────────────────────
# Snapshot TTL defaults (days)
# ──────────────────────────────────────────────
SNAPSHOT_TTL_HOTEL_OFFER=1
SNAPSHOT_TTL_FLIGHT_OFFER=1
SNAPSHOT_TTL_POI_OPENING=7
SNAPSHOT_TTL_WEATHER=1

# ──────────────────────────────────────────────
# Worker Settings
# ──────────────────────────────────────────────
WORKER_MAX_JOBS=10
JOB_RETRY_MAX=3
JOB_RETRY_DELAY_SECS=10

# ── Amadeus 机票特价监控 ──────────────────────────────
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret

# ── 通知渠道 ─────────────────────────────────────────
# 企业微信机器人 Webhook（推荐）
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

# ──────────────────────────────────────────────
# AI Observability (Langfuse) — 可选
# 不填则自动跳过追踪，不影响正常功能
# 云端免费版: https://cloud.langfuse.com
# 自托管: docker run -p 3000:3000 langfuse/langfuse
# ──────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# 邮件通知（备用）
SMTP_HOST=smtp.qq.com
SMTP_USER=your@qq.com
SMTP_PASSWORD=your_smtp_token
ALERT_EMAIL=notify@yourteam.com