#!/bin/sh
# ============================================================
# Pre-commit hook: 安全检查
#
# 安装方式 (任选一种):
#   方式1 (符号链接): git config core.hooksPath hooks
#   方式2 (复制):     cp hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#   方式3 (Windows):  copy hooks\pre-commit .git\hooks\pre-commit
# ============================================================

set -e

# ── 1. 禁止提交 .env 和其他敏感文件 ──────────────────────────────────

STAGED_FILES=$(git diff --cached --name-only 2>/dev/null || true)

# 逐文件检查敏感文件名
for f in $STAGED_FILES; do
    case "$f" in
        .env|.env.local|.env.production|.env.*.local|*.pem|*.key|id_rsa|id_ed25519)
            echo "❌ 禁止提交敏感文件: $f"
            echo "   执行 git reset HEAD $f 移除暂存"
            echo "   如果确实需要，请使用 git commit --no-verify"
            exit 1
            ;;
    esac
done

# ── 2. 检查文件内容中是否有 API Key 硬编码 ────────────────────────────

# 只检查新增/修改的文件内容（不检查删除）
CONTENT_DIFF=$(git diff --cached --diff-filter=ACM -U0 2>/dev/null || true)

if echo "$CONTENT_DIFF" | grep -qiE '(sk-[a-zA-Z0-9]{20,}|AKIA[0-9A-Z]{16}|ghp_[a-zA-Z0-9]{36}|sk-lf-[a-zA-Z0-9]{20,}|pk-lf-[a-zA-Z0-9]{20,})'; then
    echo "⚠️  检测到可能的 API Key 硬编码！"
    echo "   请检查暂存区的代码，确保没有泄露密钥。"
    echo "   如果是误报，请使用 git commit --no-verify"
    exit 1
fi

# ── 3. 检查是否意外提交了大型数据文件 ─────────────────────────────────

for f in $STAGED_FILES; do
    case "$f" in
        data/*_raw/*|data/crawled/*)
            echo "⚠️  检测到暂存的原始数据文件: $f"
            echo "   这些文件通常不应提交到 git，请确认。"
            echo "   如果确实需要，请使用 git commit --no-verify"
            exit 1
            ;;
    esac
done

exit 0