<section class="tips-page">

  <h2 class="tips-page__title">旅行实用指南</h2>

  <div class="tips-grid">

    {# 签证 #}
    {% with info = travel_info.visa if travel_info and travel_info.visa else DEFAULT_INFO.visa %}
    <div class="tips-item">
      <div class="tips-item__icon">{{ info.icon }}</div>
      <div class="tips-item__title">{{ info.title }}</div>
      <div class="tips-item__content">{{ info.content | safe }}</div>
    </div>
    {% endwith %}

    {# 天气 #}
    {% with info = travel_info.weather if travel_info and travel_info.weather else DEFAULT_INFO.weather %}
    <div class="tips-item">
      <div class="tips-item__icon">{{ info.icon }}</div>
      <div class="tips-item__title">{{ info.title }}</div>
      <div class="tips-item__content">{{ info.content | safe }}</div>
    </div>
    {% endwith %}

    {# 货币 #}
    {% with info = travel_info.currency if travel_info and travel_info.currency else DEFAULT_INFO.currency %}
    <div class="tips-item">
      <div class="tips-item__icon">{{ info.icon }}</div>
      <div class="tips-item__title">{{ info.title }}</div>
      <div class="tips-item__content">{{ info.content | safe }}</div>
    </div>
    {% endwith %}

    {# 交通 #}
    {% with info = travel_info.transport if travel_info and travel_info.transport else DEFAULT_INFO.transport %}
    <div class="tips-item">
      <div class="tips-item__icon">{{ info.icon }}</div>
      <div class="tips-item__title">{{ info.title }}</div>
      <div class="tips-item__content">{{ info.content | safe }}</div>
    </div>
    {% endwith %}

    {# 紧急电话 #}
    {% with info = travel_info.emergency if travel_info and travel_info.emergency else DEFAULT_INFO.emergency %}
    <div class="tips-item">
      <div class="tips-item__icon">{{ info.icon }}</div>
      <div class="tips-item__title">{{ info.title }}</div>
      <div class="tips-item__content">{{ info.content | safe }}</div>
    </div>
    {% endwith %}

  </div>

  {# ── 交通卡详解（扩充 C6.1）── #}
  {% set tc = DEFAULT_INFO.transport_cards %}
  <div class="transport-cards-section">
    <h3 class="transport-cards-section__title">{{ tc.icon }} {{ tc.title }}</h3>
    <div class="transport-cards-grid">
      {% for sub in tc.subsections %}
      <div class="transport-card-block">
        <div class="transport-card-block__header">
          <span class="transport-card-block__icon">{{ sub.icon }}</span>
          <span class="transport-card-block__name">{{ sub.name }}</span>
        </div>
        <ul class="transport-card-block__list">
        {% for tip in sub.tips %}
          <li class="transport-card-block__item">{{ tip }}</li>
        {% endfor %}
        </ul>
      </div>
      {% endfor %}
    </div>
  </div>

  {# 页脚版权 #}
  <div style="margin-top: 40px; padding-top: 16px; border-top: 1px solid var(--color-border);
              font-size: 11px; color: var(--color-muted); text-align: center;">
    本攻略由 Travel AI 智能生成 · 信息仅供参考，出行前请以官方渠道为准
  </div>

</section>
