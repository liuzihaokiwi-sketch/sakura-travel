    {
      "name_ja": "SAVOY 北野坂",
      "city_code": "kobe",
      "area": "北野坂・三宮",
      "type": "bar",
      "source": "choinomi.jp / icotto.jp",
      "brief_note": "三宮駅から徒歩6分、神戸を代表する老舗バー。オリジナルカクテル「ソル・クバーノ」（ラム・グレープフルーツ・トニック）はマスター木村氏の傑作。神戸バー文化の象徴。"
    },
    {
      "name_ja": "LAGUNA THE BAR",
      "city_code": "kobe",
      "area": "ハンター坂・三宮",
      "type": "bar",
      "source": "icotto.jp",
      "brief_note": "三宮駅から徒歩8分のハンター坂のオーセンティックバー。吹き抜けの天井に一枚板カウンター。注文ごとに氷を削り、グラスはほぼバカラというこだわり。"
    },
    {
      "name_ja": "BAR A-SOLUTIONS",
      "city_code": "kobe",
      "area": "生田神社西・三宮",
      "type": "bar",
      "source": "choinomi.jp",
      "brief_note": "関西一流ホテル出身のオーナーバーテンダーが2013年オープン。200種以上のウイスキーと店内熟成のオリジナルエイジングウイスキーが自慢。三宮駅から徒歩3分。"
    },
    {
      "name_ja": "SONE",
      "city_code": "kobe",
      "area": "三宮",
      "type": "bar",
      "source": "note.com/specter3196",
      "brief_note": "1969年創業、55年以上続く神戸の伝説的ミュージックバー。本格的なコース料理とライブ演奏を組み合わせた大人の夜。神戸はジャズ発祥の地としての矜持を体現する店。"
    },
    {
      "name_ja": "摩耶山 掬星台",
      "city_code": "kobe",
      "area": "摩耶山・灘区",
      "type": "night_view",
      "source": "kobe-rokko.jp (神戸六甲山公式) / nightview.info",
      "brief_note": "函館・長崎と並ぶ「日本三大夜景」の一つ。神戸から関空まで一望できる大スケールの夜景。ロープウェイとケーブルカーでアクセス可能。夜景ランキング六甲・摩耶エリア常時1位。"
    },
    {
      "name_ja": "六甲ガーデンテラス（自然体感展望台 六甲枝垂れ）",
      "city_code": "kobe",
      "area": "六甲山・灘区",
      "type": "night_view",
      "source": "kobe-rokko.jp (神戸六甲山公式)",
      "brief_note": "英国調ガーデンがライトアップされた六甲山の展望スポット。展望塔から明石海峡大橋まで見渡せる。ショッピング・レストランと組み合わせて夜の六甲を楽しめる。"
    },
    {
      "name_ja": "ビーナスブリッジ",
      "city_code": "kobe",
      "area": "諏訪山・中央区",
      "type": "night_view",
      "source": "kobe-rokko.jp (神戸六甲山公式) / jalan.net",
      "brief_note": "三宮から車で10分の諏訪山公園上にある恋人の聖地。神戸港と市街地の夜景を見下ろす展望スポット。六甲山より手軽にアクセスでき、ドライブデートに最適。"
    }
