{
  "version": "1.0",
  "description": "关西城市圈景点/活动分类体系 + 评级框架",

  "main_types": {
    "fixed_spot": {
      "zh": "固定地点类",
      "description": "有明确地址的景点",
      "sub_types": {
        "culture_art": { "zh": "文化艺术", "examples": "美术馆、博物馆、文化设施" },
        "history_religion": { "zh": "历史宗教", "examples": "神社、寺庙、古城、遗迹" },
        "landmark_view": { "zh": "地标观景", "examples": "展望台、标志性建筑、观景点" },
        "animal_science": { "zh": "动物海洋科普", "examples": "水族馆、动物园、科学馆" },
        "nature_scenery": { "zh": "自然景观", "examples": "公园、山、湖、瀑布、海岸" },
        "amusement": { "zh": "游乐休闲", "examples": "主题乐园、娱乐设施" },
        "shopping_specialty": { "zh": "购物/特色店铺", "examples": "商场、市场、特色街" }
      }
    },
    "area_dest": {
      "zh": "区域目的地类",
      "description": "以逛一片区域为主",
      "sub_types": {
        "historic_district": { "zh": "老城历史区", "examples": "保存完好的历史街区" },
        "shopping_district": { "zh": "商圈购物区", "examples": "集中购物/美食的区域" },
        "onsen_resort": { "zh": "温泉/度假区", "examples": "温泉街、度假目的地" }
      }
    },
    "experience": {
      "zh": "体验/活动类",
      "description": "要做的事",
      "sub_types": {
        "day_trip": { "zh": "半日/一日游", "examples": "需要专门安排的行程" },
        "cultural_exp": { "zh": "文化体验", "examples": "和服、茶道、料理教室" },
        "outdoor_sport": { "zh": "户外运动", "examples": "登山、骑行、皮划艇" },
        "night_show": { "zh": "演出夜游", "examples": "表演、夜景、夜间活动" },
        "seasonal_event": { "zh": "节庆限定", "examples": "季节性活动/祭典" }
      }
    }
  },

  "feature_tags": [
    "特色景点",
    "特色商店",
    "品牌体验馆",
    "百年老店",
    "城市代表伴手礼点",
    "工厂参观",
    "本地限定",
    "复合型目的地"
  ],

  "condition_tags": [
    "亲子",
    "雨天友好",
    "拍照强",
    "夜间强",
    "无障碍",
    "免费",
    "需预约"
  ],

  "grade_system": {
    "S": {
      "zh": "关西名片",
      "definition": "去关西就该去，不去等于没来",
      "decision": "关西行程的核心骨架",
      "approx_count_kansai": "10-15"
    },
    "A": {
      "zh": "目的地级",
      "definition": "值得为它专门安排半天以上，或特定画像的必去",
      "decision": "为了它去那个城市/区域",
      "approx_count_kansai": "30-50"
    },
    "B": {
      "zh": "行程增色",
      "definition": "值得编入当天计划，让行程更丰富",
      "decision": "今天排上这个更好",
      "approx_count_kansai": "50-80"
    },
    "C": {
      "zh": "顺路收录",
      "definition": "附近才去，不值得专程",
      "decision": "反正在旁边看一眼",
      "approx_count_kansai": "不限"
    }
  },

  "profile_dimensions": {
    "first_kansai": { "zh": "首次关西", "desc": "第一次来，时间3-5天" },
    "revisit": { "zh": "深度复访", "desc": "第二次以上，想看不一样的" },
    "family_kids": { "zh": "亲子", "desc": "带小孩" },
    "couple": { "zh": "情侣", "desc": "约会/蜜月" },
    "culture_deep": { "zh": "文化深度游", "desc": "对历史宗教特别感兴趣" },
    "nature_outdoor": { "zh": "自然户外", "desc": "喜欢徒步、自然景观" },
    "foodie": { "zh": "美食控", "desc": "以吃为核心" },
    "photo": { "zh": "拍照党", "desc": "出片优先" },
    "time_tight": { "zh": "时间紧", "desc": "3天以内快节奏" }
  },

  "profile_boost_rules": {
    "description": "对某画像升/降一级，+1=升一级，-1=降一级",
    "example": {
      "海游馆": { "base": "B", "boosts": { "family_kids": "+1", "couple": "+1" } },
      "姫路城": { "base": "A", "boosts": { "culture_deep": "+1", "time_tight": "-1" } },
      "USJ": { "base": "S", "boosts": { "culture_deep": "-1" } }
    }
  },

  "seasonal_event_schema": {
    "name_zh": "string",
    "name_ja": "string",
    "location": "string",
    "city_code": "string",
    "event_type": "sakura | autumn_leaves | festival | illumination | fireworks | matsuri | food_event | other",
    "date_range": "string (e.g. '3月下旬-4月上旬' or '7月1日-7月31日')",
    "recurring": "annual | one_time",
    "grade": "S|A|B|C",
    "description": "string",
    "tips": "string"
  },

  "regions": {
    "osaka": {
      "zh": "大阪",
      "sub_regions": ["大阪市区", "堺", "岸和田"]
    },
    "kyoto": {
      "zh": "京都",
