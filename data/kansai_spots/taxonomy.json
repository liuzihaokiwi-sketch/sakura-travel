      "sub_regions": ["伊势", "志摩", "名張"]
    },
    "fukui": {
      "zh": "福井",
      "sub_regions": ["福井市", "敦贺", "勝山"]
    },
    "tottori": {
      "zh": "鸟取",
      "sub_regions": ["鸟取市", "境港"]
    },
    "tokushima": {
