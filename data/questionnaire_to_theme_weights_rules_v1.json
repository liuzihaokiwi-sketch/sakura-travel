  "questionnaire_signal_rules": [
    {
      "question_id": "q1",
      "question": "你这次最期待日本旅行的哪些体验？（多选）",
      "options_to_weights": {
        "购物血拼": {
          "shopping": 0.5
        },
        "美食探店": {
          "food": 0.5
        },
        "泡温泉": {
          "onsen_relaxation": 0.6
        },
        "自然风景": {
          "nature_outdoors": 0.5
        },
        "历史文化": {
          "culture_history": 0.5
        },
        "动漫圣地": {
          "anime_pop_culture": 0.7
        },
        "亲子游乐": {
          "family_kids": 0.6
        },
        "夜生活": {
          "nightlife_entertainment": 0.5
        },
        "拍照出片": {
          "photography_scenic": 0.5
        }
      },
      "rule_note": "这是主权重入口；一个选项通常只给 1-2 个维度加权，避免所有维度一起涨。"
    },
    {
      "question_id": "q2",
      "question": "这次同行人是谁？（单选/多选）",
      "options_to_weights": {
        "情侣/配偶": {
          "photography_scenic": 0.1,
          "food": 0.1
        },
        "带小孩": {
          "family_kids": 0.4
        },
        "独自旅行": {
          "culture_history": 0.1,
          "onsen_relaxation": 0.1
        },
        "带父母/长辈": {
          "onsen_relaxation": 0.2,
          "culture_history": 0.1
        }
      },
      "rule_note": "同行人不直接决定高权重，但会微调旅行风格。"
    },
    {
      "question_id": "q3",
      "question": "你是第一次去日本，还是已经去过？",
      "options_to_weights": {
        "第一次去": {
          "shopping": 0.1,
          "food": 0.1,
          "photography_scenic": 0.1
        },
        "去过一次或多次": {
          "culture_history": 0.2,
          "onsen_relaxation": 0.1
        }
      },
      "rule_note": "首次用户通常更偏经典体验与高回报；二刷用户更容易追求深度文化和温泉。"
    },
    {
      "question_id": "q4",
      "question": "你更喜欢哪种节奏？",
      "options_to_weights": {
        "想住好一点、慢慢玩": {
          "onsen_relaxation": 0.3
        },
        "能多看就多看": {
          "photography_scenic": 0.1,
          "culture_history": 0.1
        },
        "不赶景点，重体验": {
          "food": 0.2,
          "onsen_relaxation": 0.2,
          "culture_history": 0.1
        },
        "想玩热闹一点": {
          "nightlife_entertainment": 0.3,
          "shopping": 0.2
        }
      },
      "rule_note": "节奏题主要用来调休闲/热闹方向，不单独决定主题核心。"
    },
    {
      "question_id": "q5",
      "question": "你对以下项目有没有特别想安排的？（多选）",
      "options_to_weights": {
        "樱花/红叶": {
          "nature_outdoors": 0.3,
          "photography_scenic": 0.3
        },
        "富士山/雪景": {
          "nature_outdoors": 0.4,
          "photography_scenic": 0.4
        },
        "寺庙神社/古街": {
          "culture_history": 0.4,
          "photography_scenic": 0.2
        },
        "游乐园/动物园/水族馆": {
          "family_kids": 0.5
        },
        "买动漫周边/圣地巡礼": {
          "anime_pop_culture": 0.6,
          "shopping": 0.2
        },
        "会席/怀石/高级和食": {
          "food": 0.4,
          "culture_history": 0.1
        },
        "温泉旅馆住一晚": {
          "onsen_relaxation": 0.5
        },
        "酒吧/夜景/夜游": {
          "nightlife_entertainment": 0.4,
          "photography_scenic": 0.1
        }
      },
      "rule_note": "这是第二强的加权入口，适合把模糊偏好变成更明确的主题画像。"
    }
  ],
  "aggregation_rules": {
    "method": "additive_with_cap",
    "formula": "每个维度初始值为0；命中问卷信号后按规则累加；单维度上限封顶为1.0。",
    "post_processing": [
      "若 family_kids >= 0.6，则 nightlife_entertainment 默认最多保留到 0.2，除非用户明确强调夜生活。",
      "若 anime_pop_culture >= 0.7，则 shopping 至少提升到 0.2（周边购物通常伴生）。",
      "若 onsen_relaxation >= 0.8，则 nightlife_entertainment 默认压到 0.1 以下，除非用户明确强调夜生活。",
      "若 photography_scenic >= 0.8 且 nature_outdoors == 0，则不自动补自然分，因为城市夜景/街拍也可能带来纯出片偏好。",
      "若 culture_history >= 0.8 且 first_time，允许 shopping/food 保持中低权重，不强行压掉经典体验。"
    ],
    "implementation_hint": "建议先根据问卷选项累加 theme_weights，再根据 post_processing 做微调，最后交给系统归一化。"
  }
}