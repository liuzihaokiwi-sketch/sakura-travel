{
  "schema_version": "1.0",
  "type": "questionnaire_to_weights_rules",
  "themes": [
    "shopping",
    "food",
    "culture_history",
    "onsen_relaxation",
    "nature_outdoors",
    "anime_pop_culture",
    "family_kids",
    "nightlife_entertainment",
    "photography_scenic"
  ],
  "weight_rules": {
    "range": [
      0.0,
      1.0
    ],
    "normalization": "系统后续自行归一化；本规则只负责给出相对强弱。",
    "interpretation": {
      "0.0": "未提到或明显不相关",
      "0.1_0.2": "弱相关/顺带需求",
      "0.3_0.5": "明确提到/中等重要",
      "0.6_0.8": "强偏好/主要目的之一",
      "0.9_1.0": "核心目的/强驱动"
    }
  },
  "profiles": [
